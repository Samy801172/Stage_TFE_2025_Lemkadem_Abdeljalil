# Configuration de la base de données
DATABASE_HOST=your-render-db-host
DATABASE_PORT=5432
DATABASE_USERNAME=your-db-username
DATABASE_PASSWORD=your-db-password
DATABASE_NAME=your-db-name

# Configuration JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=24h

# Configuration du serveur
PORT=2024
NODE_ENV=production

# Configuration Google OAuth
GOOGLE_CLIENT_ID=447804059370-3hq60m3iik50cvltiiu8npfl7h2310hn.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend-url.onrender.com/auth/google/callback

# Configuration Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Configuration Email (SendGrid ou autre)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@kiwiclub.com

# Configuration Firebase (si utilisé)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Configuration CORS
CORS_ORIGIN=https://your-flutter-app.onrender.com

# Configuration Cloudinary (si utilisé)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
